# =============================================================================
# Mismo - environment variables (copy to .env.local, never commit secrets)
# =============================================================================
#
# FRONTEND RULE: Only VITE_* vars below. No database vendor keys in the browser.
# The app talks to Mismo API - users never see the database provider.
#
# =============================================================================

# --- Frontend (Vite) ---
# Supabase project (required for production auth + data):
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
# Must match organizations.id from docs/database/06_production_bootstrap.sql
VITE_ORG_ID=org-mismo-1
VITE_ORG_NAME=Organization
# Optional override (defaults to {VITE_SUPABASE_URL}/functions/v1/mismo-api):
# VITE_API_BASE_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/mismo-api
VITE_AI_FEATURES_ENABLED=true

# Local-only fallback (instead of Supabase functions):
# VITE_API_BASE_URL=http://localhost:3001

# --- API server secrets → services/api/.env (see services/api/.env.example) ---
# Do NOT put DATABASE_URL, OPENAI_API_KEY, or service role keys in this file.
